  <style>
/* =========================================================
   Servicio Directo Exprés — styles.css
   Reparación de línea blanca — CDMX
   ========================================================= */

/* ---------- 1. Tokens ---------- */
:root {
  /* Marca */
  --sky: #F8C6DE;
  --sky-soft: #FDE7F3;
  --royal: #C81F6C;
  --royal-dark: #9C1755;
  --orange: #EF3282;
  --orange-dark: #D01F72;

  /* Neutros */
  --white: #FFFFFF;
  --ink: #2B1424;
  --ink-soft: #6B5262;
  --ink-faint: #A98BA0;
  --bg-tint: #FDF3F8;
  --line: #F6DCEB;

  /* Sombras */
  --shadow-sm: 0 2px 10px rgba(156, 23, 85, 0.08);
  --shadow-md: 0 14px 34px rgba(156, 23, 85, 0.12);
  --shadow-lg: 0 26px 60px rgba(156, 23, 85, 0.16);
  --shadow-orange: 0 14px 30px rgba(239, 50, 130, 0.32);

  /* Radios */
  --r-sm: 12px;
  --r-md: 20px;
  --r-lg: 28px;
  --r-pill: 999px;

  /* Tipografía */
  --font-display: 'Poppins', 'Segoe UI', sans-serif;
  --font-body: 'Inter', 'Segoe UI', sans-serif;

  /* Transiciones */
  --ease: cubic-bezier(.22, .8, .3, 1);
  --t-fast: .22s;
  --t-med: .45s;
}

/* ---------- 2. Reset ---------- */
*, *::before, *::after { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0;
  font-family: var(--font-body);
  color: var(--ink);
  background: var(--white);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}
img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }
ul { list-style: none; margin: 0; padding: 0; }
h1, h2, h3, h4 { font-family: var(--font-display); margin: 0; color: var(--ink); }
p { margin: 0; }
button { font-family: inherit; cursor: pointer; }

@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
  *, *::before, *::after {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
    scroll-behavior: auto !important;
  }
}

:focus-visible {
  outline: 3px solid var(--orange);
  outline-offset: 3px;
  border-radius: 4px;
}

.container {
  width: 100%;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: 24px;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-display);
  font-size: .78rem;
  font-weight: 600;
  letter-spacing: .09em;
  text-transform: uppercase;
  color: var(--royal);
  background: var(--sky-soft);
  padding: 7px 16px;
  border-radius: var(--r-pill);
}
.eyebrow--center { align-self: center; }

/* ---------- 3. Botones ---------- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  font-family: var(--font-display);
  font-weight: 600;
  font-size: .95rem;
  border-radius: var(--r-pill);
  padding: 13px 26px;
  border: 2px solid transparent;
  transition: transform var(--t-fast) var(--ease), box-shadow var(--t-fast) var(--ease), background var(--t-fast) var(--ease), color var(--t-fast) var(--ease);
  white-space: nowrap;
}
.btn:hover { transform: translateY(-3px); }
.btn:active { transform: translateY(-1px); }

.btn--primary {
  background: linear-gradient(135deg, #EF3282, #D01F72);
  color: var(--white);
  box-shadow: var(--shadow-orange);
}
.btn--primary:hover { box-shadow: 0 18px 38px rgba(239, 50, 130, .42); }

.btn--outline {
  background: var(--white);
  color: var(--royal);
  border-color: var(--royal);
}
.btn--outline:hover { background: var(--royal); color: var(--white); }

.btn--ghost {
  background: transparent;
  color: var(--royal);
}
.btn--ghost:hover { color: var(--royal-dark); }

.btn--sm { padding: 9px 16px; font-size: .85rem; }
.btn--lg { padding: 16px 30px; font-size: 1rem; }

/* ---------- 4. Header ---------- */
.header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  background: var(--white);
  transition: box-shadow var(--t-fast);
}
.header.is-scrolled {
  box-shadow: 0 8px 24px rgba(156, 23, 85, .08);
}

.header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  padding-block: 14px;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 12px;
}
.brand__mark { flex-shrink: 0; line-height: 0; }
.brand__text { display: flex; flex-direction: column; line-height: 1.15; }
.brand__name { font-family: var(--font-display); font-weight: 700; font-size: 1.02rem; color: var(--ink); }
.brand__tag { font-size: .72rem; color: var(--ink-faint); font-weight: 500; }

.nav__list {
  display: flex;
  align-items: center;
  gap: 30px;
}
.nav__link {
  font-family: var(--font-display);
  font-size: .92rem;
  font-weight: 500;
  color: var(--ink-soft);
  position: relative;
  padding-block: 4px;
  transition: color var(--t-fast);
}
.nav__link::after {
  content: '';
  position: absolute;
  left: 0; bottom: -2px;
  width: 0; height: 2px;
  background: var(--orange);
  transition: width var(--t-fast) var(--ease);
  border-radius: 2px;
}
.nav__link:hover { color: var(--royal); }
.nav__link:hover::after { width: 100%; }

.header__actions { display: flex; align-items: center; gap: 10px; }

.nav__toggle {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 40px;
  height: 40px;
  background: transparent;
  border: none;
  padding: 0;
}
.nav__toggle span {
  width: 100%;
  height: 2px;
  background: var(--royal);
  border-radius: 2px;
  transition: transform var(--t-fast) var(--ease), opacity var(--t-fast) var(--ease);
}
.nav__toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav__toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
.nav__toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ---------- 5. Hero ---------- */
.hero {
  position: relative;
  padding-top: 140px;
  padding-bottom: 90px;
  overflow: hidden;
  background: var(--white);
}
.hero__bg {
  position: absolute;
  inset: 0;
  z-index: -1;
  background:
    radial-gradient(700px 460px at 82% 12%, rgba(239, 50, 130, .18), transparent 60%),
    radial-gradient(520px 420px at -5% 90%, rgba(156, 23, 85, .10), transparent 60%);
}

.hero__inner {
  display: flex;
  justify-content: center;
}

.hero__copy {
  max-width: 720px;
  text-align: center;
}

.hero__title {
  font-size: clamp(2.1rem, 4vw, 3.4rem);
  line-height: 1.12;
  font-weight: 700;
  margin-block: 18px 14px;
  color: var(--ink);
}

.hero__subtitle {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--royal);
  margin-bottom: 12px;
}

.hero__text {
  font-size: 1.02rem;
  line-height: 1.65;
  color: var(--ink-soft);
  max-width: 56ch;
  margin-inline: auto;
}

.hero__actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14px;
  margin-top: 30px;
}

.hero__trust {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 26px;
  margin-top: 34px;
  padding-top: 26px;
  border-top: 1px solid var(--line);
  font-size: .86rem;
  color: var(--ink-soft);
}
.hero__trust strong {
  display: block;
  font-family: var(--font-display);
  font-size: 1.3rem;
  color: var(--royal);
}

/* ---------- 6. Secciones genéricas ---------- */
.section { padding-block: 96px; background: var(--white); }
.section--tint { background: var(--bg-tint); }

.section__head {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 640px;
  margin: 0 auto 56px;
}
.section__title {
  font-size: clamp(1.7rem, 3vw, 2.3rem);
  font-weight: 700;
  margin-top: 14px;
  line-height: 1.2;
}
.section__lead {
  margin-top: 14px;
  color: var(--ink-soft);
  font-size: 1rem;
  line-height: 1.6;
}

/* ---------- 7. Servicios ---------- */
.services-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

.service-card {
  background: var(--white);
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  padding: 26px;
  box-shadow: var(--shadow-sm);
  transition: transform var(--t-med) var(--ease), box-shadow var(--t-med) var(--ease), border-color var(--t-med);
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.service-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-lg);
  border-color: rgba(200, 31, 108, .18);
}

.service-card__icon {
  width: 58px; height: 58px;
  border-radius: 16px;
  background: var(--sky-soft);
  display: grid;
  place-items: center;
  transition: background var(--t-fast), transform var(--t-fast);
}
.service-card:hover .service-card__icon {
  background: var(--royal);
  transform: rotate(-6deg) scale(1.05);
}
.service-card:hover .service-card__icon svg path,
.service-card:hover .service-card__icon svg rect,
.service-card:hover .service-card__icon svg circle {
  stroke: var(--white);
}

.service-card__body h3 {
  font-size: 1.05rem;
  font-weight: 600;
  margin-bottom: 8px;
}
.service-card__body p {
  font-size: .9rem;
  color: var(--ink-soft);
  line-height: 1.55;
}

.service-card--photo { padding: 0; overflow: hidden; }
.service-card--photo .service-card__media {
  background: linear-gradient(180deg, var(--sky-soft), #FFFFFF);
  padding: 22px 22px 0;
  height: 210px;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  overflow: hidden;
}
.service-card--photo .service-card__media img {
  height: 100%;
  width: auto;
  object-fit: contain;
  transition: transform var(--t-med) var(--ease);
  filter: drop-shadow(0 14px 16px rgba(156, 23, 85, .18));
}
.service-card--photo:hover .service-card__media img { transform: translateY(-6px) scale(1.04); }
.service-card--photo .service-card__body { padding: 22px 24px 26px; }

/* ---------- 8. Por qué elegirnos ---------- */
.why-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}
.why-card {
  background: var(--white);
  border-radius: var(--r-md);
  padding: 30px 26px;
  box-shadow: var(--shadow-sm);
  transition: transform var(--t-med) var(--ease), box-shadow var(--t-med) var(--ease);
}
.why-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); }
.why-card__check {
  display: grid;
  place-items: center;
  width: 42px; height: 42px;
  border-radius: 50%;
  background: var(--royal);
  margin-bottom: 18px;
}
.why-card h3 { font-size: 1.02rem; font-weight: 600; margin-bottom: 8px; }
.why-card p { font-size: .89rem; color: var(--ink-soft); line-height: 1.55; }

/* ---------- 9. Compromiso ---------- */
.commitment {
  background: linear-gradient(135deg, var(--sky-soft) 0%, #FCEAF4 60%, #FEF7FB 100%);
  padding-block: 96px;
}
.commitment__inner {
  display: grid;
  grid-template-columns: 1fr .85fr;
  align-items: center;
  gap: 50px;
}
.commitment__title {
  font-size: clamp(1.6rem, 3vw, 2.15rem);
  font-weight: 700;
  margin-block: 16px 16px;
  line-height: 1.25;
}
.commitment__text {
  font-size: 1.02rem;
  color: var(--ink-soft);
  line-height: 1.7;
  max-width: 50ch;
  margin-bottom: 28px;
}
.commitment__art { max-width: 420px; margin-inline: auto; }

/* ---------- 10. Marcas ---------- */
.marquee {
  overflow: hidden;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  padding-block: 28px;
  mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
}
.marquee__track {
  display: flex;
  align-items: center;
  gap: 56px;
  width: max-content;
  animation: scroll-left 28s linear infinite;
}
.marquee:hover .marquee__track { animation-play-state: paused; }
.marquee__item {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 1.3rem;
  color: var(--ink-faint);
  letter-spacing: .02em;
  white-space: nowrap;
  transition: color var(--t-fast);
}
.marquee__item:hover { color: var(--royal); }

@keyframes scroll-left {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* ---------- 11. Contacto ---------- */
.contact-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
  margin-bottom: 44px;
}
.contact-card {
  background: var(--white);
  border-radius: var(--r-md);
  padding: 30px 26px;
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: transform var(--t-med) var(--ease), box-shadow var(--t-med) var(--ease);
}
.contact-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); }
.contact-card__icon {
  display: grid;
  place-items: center;
  width: 52px; height: 52px;
  margin: 0 auto 16px;
  border-radius: 50%;
  background: var(--sky-soft);
}
.contact-card h3 { font-size: .82rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--ink-faint); margin-bottom: 8px; }
.contact-card p { font-size: 1.1rem; font-weight: 600; font-family: var(--font-display); color: var(--ink); line-height: 1.4; }
.contact-card p a { transition: color var(--t-fast); }
.contact-card p a:hover { color: var(--royal); }

.contact-cta {
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
}

/* ---------- 12. Footer ---------- */
.footer { background: var(--royal); color: var(--white); }
.footer__inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  padding-block: 40px;
}
.footer__brand { display: flex; align-items: center; gap: 12px; }
.footer__brand strong { display: block; font-family: var(--font-display); font-size: 1rem; }
.footer__brand span { font-size: .78rem; color: rgba(255, 255, 255, .7); }
.footer__area { font-size: .88rem; color: rgba(255, 255, 255, .85); }
.footer__contact { display: flex; gap: 20px; font-weight: 600; font-size: .9rem; }
.footer__contact a { transition: opacity var(--t-fast); }
.footer__contact a:hover { opacity: .75; }

.footer__bottom {
  border-top: 1px solid rgba(255, 255, 255, .16);
  padding-block: 18px;
  text-align: center;
  font-size: .8rem;
  color: rgba(255, 255, 255, .7);
}

/* ---------- 13. Floating buttons ---------- */
.float-whatsapp {
  position: fixed;
  right: 22px;
  bottom: 22px;
  width: 60px; height: 60px;
  border-radius: 50%;
  background: linear-gradient(135deg, #25D366, #1EBE57);
  color: var(--white);
  display: grid;
  place-items: center;
  box-shadow: 0 14px 30px rgba(37, 211, 102, .45);
  z-index: 90;
  transition: transform var(--t-fast) var(--ease);
}
.float-whatsapp:hover { transform: scale(1.08); }
.float-whatsapp__pulse {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: rgba(37, 211, 102, .55);
  animation: pulse 2.2s ease-out infinite;
}
@keyframes pulse {
  0% { transform: scale(1); opacity: .65; }
  100% { transform: scale(1.9); opacity: 0; }
}

.float-top {
  position: fixed;
  right: 22px;
  bottom: 92px;
  width: 46px; height: 46px;
  border-radius: 50%;
  background: var(--white);
  color: var(--royal);
  border: 1px solid var(--line);
  box-shadow: var(--shadow-sm);
  display: grid;
  place-items: center;
  z-index: 90;
  opacity: 0;
  visibility: hidden;
  transform: translateY(10px);
  transition: opacity var(--t-fast), transform var(--t-fast), visibility var(--t-fast);
}
.float-top.is-visible { opacity: 1; visibility: visible; transform: translateY(0); }
.float-top:hover { background: var(--royal); color: var(--white); }

/* ---------- 14. (animación de aparición retirada por estabilidad) ---------- */

/* ---------- 15. Responsive ---------- */
@media (max-width: 1080px) {
  .services-grid { grid-template-columns: repeat(2, 1fr); }
  .why-grid { grid-template-columns: repeat(2, 1fr); }
  .contact-grid { grid-template-columns: 1fr; max-width: 420px; margin-inline: auto; margin-bottom: 44px; }
}

@media (max-width: 900px) {
  .nav { display: none; }
  .header__actions .btn--ghost span { display: none; }

  .hero__actions { justify-content: center; }
  .hero__trust { justify-content: center; }

  .commitment__inner { grid-template-columns: 1fr; text-align: center; }
  .commitment__text { margin-inline: auto; }
  .commitment__art { order: -1; max-width: 320px; }
}

@media (max-width: 640px) {
  .services-grid { grid-template-columns: 1fr; }
  .why-grid { grid-template-columns: 1fr; }
  .hero { padding-top: 120px; padding-bottom: 60px; }
  .hero__title { font-size: 2rem; }
  .hero__actions { flex-direction: column; width: 100%; }
  .hero__actions .btn { width: 100%; }
  .hero__trust { gap: 18px; }
  .section { padding-block: 64px; }
  .commitment { padding-block: 64px; }
  .contact-cta { flex-direction: column; width: 100%; }
  .contact-cta .btn { width: 100%; }
  .footer__inner { flex-direction: column; text-align: center; }
}

</style>

